<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_height"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical">

    <!-- Top Header Bar -->
    <RelativeLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/bg_surface"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/logo_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerY="true"
            android:text="CODE QUEST"
            android:textColor="@color/neon_cyan"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- XP Pill -->
            <LinearLayout
                android:id="@+id/xp_pill_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pill_xp_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ "
                    android:textColor="#D1ADFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/header_xp_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="150 XP"
                    android:textColor="#D1ADFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <!-- Streak Pill -->
            <LinearLayout
                android:id="@+id/streak_pill_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pill_streak_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 "
                    android:textColor="#FF85BE"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/header_streak_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 Day"
                    android:textColor="#FF85BE"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <!-- Small Profile Circle -->
            <TextView
                android:id="@+id/header_profile_circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/avatar_bg"
                android:gravity="center"
                android:text="GC"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>
    </RelativeLayout>

    <!-- Main Container -->
    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp" />

    <!-- Custom Bottom Navigation Bar -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@color/bg_surface"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/bottom_nav_layout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <!-- Profile Nav Button -->
            <LinearLayout
                android:id="@+id/nav_btn_profile"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/nav_lbl_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textColor="@color/text_main"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Quest Arena Button -->
            <LinearLayout
                android:id="@+id/nav_btn_arena"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚔️"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/nav_lbl_arena"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Arena"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- System Design Button -->
            <LinearLayout
                android:id="@+id/nav_btn_design"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏗️"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/nav_lbl_design"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Design"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Leaderboard Button -->
            <LinearLayout
                android:id="@+id/nav_btn_leaderboard"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/nav_lbl_leaderboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ranks"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Guild Button -->
            <LinearLayout
                android:id="@+id/nav_btn_guild"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/nav_lbl_guild"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guild"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Trophy Case Button -->
            <LinearLayout
                android:id="@+id/nav_btn_trophy"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎖️"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/nav_lbl_trophy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trophies"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- System Logs Dev Button -->
            <LinearLayout
                android:id="@+id/nav_btn_logs"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📟"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/nav_lbl_logs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logs"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
