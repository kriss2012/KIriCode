<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guild Hub"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Coordinate raids and chat with Binary Beasts team members."
        android:textColor="@color/text_muted"
        android:textSize="12sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="16dp" />

    <!-- Guild Card details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_bg"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Binary Beasts"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="#2000E5FF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="LEVEL 14"
                android:textColor="@color/neon_cyan"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Active Raid card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#10FF007F"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Raid: Infinite Loops"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cooperative challenge in C++"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />
            </LinearLayout>

            <Button
                android:id="@+id/guild_btn_join_raid"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/shortcut_key_bg"
                android:paddingHorizontal="12dp"
                android:text="Join Raid"
                android:textAllCaps="false"
                android:textColor="@color/neon_magenta"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Chat Messages Frame -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="#090618"
        android:orientation="vertical">

        <ScrollView
            android:id="@+id/guild_chat_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/guild_chat_messages_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <!-- Message input bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bg_surface"
            android:orientation="horizontal"
            android:padding="6dp">

            <EditText
                android:id="@+id/guild_chat_input"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Type a message..."
                android:imeOptions="actionSend"
                android:inputType="textShortMessage"
                android:paddingHorizontal="10dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_muted"
                android:textSize="13sp" />

            <Button
                android:id="@+id/guild_btn_send"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/btn_cyan_bg"
                android:text="Send"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
