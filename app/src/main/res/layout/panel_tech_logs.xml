<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Telemetry &amp; Logs"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Visualize request lifecycles, sandbox logs, Kafka event queues, and run server CLI commands."
        android:textColor="@color/text_muted"
        android:textSize="12sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="16dp" />

    <!-- Split Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top half: Pipeline steps -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/card_bg"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pipeline Telemetry"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Step 1 -->
                <LinearLayout
                    android:id="@+id/tech_step_1_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. Kong API Gateway Proxy [POST /api/v1/submissions]"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tech_payload_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="#05000000"
                        android:padding="6dp"
                        android:text="Waiting for submission..."
                        android:textColor="#B3C9FF"
                        android:fontFamily="monospace"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout
                    android:id="@+id/tech_step_2_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2. nsjail Sandbox Judge"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tech_payload_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="#05000000"
                        android:padding="6dp"
                        android:text="Waiting for judge..."
                        android:textColor="#B3C9FF"
                        android:fontFamily="monospace"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout
                    android:id="@+id/tech_step_3_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3. Kafka Submission Event Queue"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tech_payload_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="#05000000"
                        android:padding="6dp"
                        android:text="Waiting for event..."
                        android:textColor="#B3C9FF"
                        android:fontFamily="monospace"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Step 4 -->
                <LinearLayout
                    android:id="@+id/tech_step_4_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4. Redis Sorted Set [ZADD leaderboards]"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tech_payload_4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="#05000000"
                        android:padding="6dp"
                        android:text="Waiting for rank update..."
                        android:textColor="#B3C9FF"
                        android:fontFamily="monospace"
                        android:textSize="10sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="1dp"
            android:layout_height="10dp" />

        <!-- Bottom half: Command Console CLI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#020108"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="#0D0A21"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="CODE QUEST SYSTEM CONSOLE v1.0"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Console logs scroll -->
            <ScrollView
                android:id="@+id/tech_console_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tech_console_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome to Code Quest System CLI.\nType 'help' to see developer options.\n\n"
                    android:textColor="#D1CCFF"
                    android:fontFamily="monospace"
                    android:textSize="11sp" />
            </ScrollView>

            <!-- CLI text input line -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="#070514"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&gt; "
                    android:textColor="@color/neon_magenta"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/tech_console_input"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:textColor="@color/white"
                    android:fontFamily="monospace"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
