<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Design Arena"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Select and link the correct pipeline components to handle real-time leaderboard scaling."
        android:textColor="@color/text_muted"
        android:textSize="12sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="16dp" />

    <!-- Description card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_bg"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scaling Leaderboard Pipelines"
            android:textColor="@color/neon_cyan"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Goal: Process 10k submissions/min, sandbox run them securely, recalculate ranks, and broadcast changes over WebSockets in &lt; 2 seconds."
            android:textColor="@color/text_main"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Component Selection List -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="SELECT A COMPONENT BLOCK"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/design_comp_selector_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <!-- Added dynamically in code -->
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Diagram Flow Canvas card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@drawable/card_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Grid of diagram nodes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Node Kong -->
            <TextView
                android:id="@+id/node_kong"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:background="@drawable/shortcut_key_bg"
                android:gravity="center"
                android:padding="8dp"
                android:text="1. Kong API Gateway\n[Linked]"
                android:textColor="@color/white"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬇"
                android:textColor="@color/border_color"
                android:textSize="14sp" />

            <!-- Row for NestJS & Sandbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/node_nestjs"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shortcut_key_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="2. NestJS Game Svc\n[Broken - Needs Gateway]"
                    android:textColor="@color/white"
                    android:textSize="11sp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/node_nsjail"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shortcut_key_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="3. nsjail Sandbox\n[Linked]"
                    android:textColor="@color/white"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬇"
                android:textColor="@color/border_color"
                android:textSize="14sp" />

            <!-- Node Kafka -->
            <TextView
                android:id="@+id/node_kafka"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:background="@drawable/shortcut_key_bg"
                android:gravity="center"
                android:padding="8dp"
                android:text="4. Kafka Event Queue\n[Broken - Needs Queue]"
                android:textColor="@color/white"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬇"
                android:textColor="@color/border_color"
                android:textSize="14sp" />

            <!-- Row for Redis & Postgres -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/node_redis"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shortcut_key_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="5. Redis Ranks\n[Linked]"
                    android:textColor="@color/white"
                    android:textSize="11sp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/node_postgres"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shortcut_key_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="6. PostgreSQL DB\n[Linked]"
                    android:textColor="@color/white"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/design_btn_validate"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@drawable/btn_cyan_bg"
            android:text="Validate Architecture"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
