<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Language & Quest Select Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <Spinner
            android:id="@+id/arena_language_spinner"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:background="@drawable/shortcut_key_bg"
            android:textColor="@color/white" />

        <View
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <Spinner
            android:id="@+id/arena_quest_spinner"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/shortcut_key_bg"
            android:textColor="@color/white" />
    </LinearLayout>

    <!-- Collapsible Quest Description Card -->
    <LinearLayout
        android:id="@+id/arena_desc_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_bg"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/arena_quest_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Two Sum Summation"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/arena_quest_difficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="#2000FF88"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="EASY"
                android:textColor="@color/neon_green"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/arena_quest_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Write a function two_sum(nums, target) that returns indices of the two numbers such that they add up to target.\n\nExample:\ntwo_sum([2, 7, 11, 15], 9) -> [0, 1]."
            android:textColor="@color/text_main"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Code Editor Arena -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="#060410"
        android:orientation="vertical">

        <!-- Toolbar controls -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/bg_surface"
            android:paddingHorizontal="8dp">

            <TextView
                android:id="@+id/arena_editor_lang_lbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="PYTHON SANDBOX"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/arena_btn_run"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/shortcut_key_bg"
                    android:paddingHorizontal="12dp"
                    android:text="Run Tests"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="11sp" />

                <View
                    android:layout_width="6dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/arena_btn_submit"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_cyan_bg"
                    android:paddingHorizontal="12dp"
                    android:text="Submit"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Code Input area -->
        <EditText
            android:id="@+id/arena_code_input"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@null"
            android:gravity="top|start"
            android:inputType="textMultiLine|textNoSuggestions"
            android:padding="12dp"
            android:textColor="#D8D4FF"
            android:fontFamily="monospace"
            android:textSize="13sp" />

        <!-- Key Shortcuts bar -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@color/bg_surface"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/arena_shortcuts_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">
                <!-- Buttons added dynamically in code -->
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Console panel logs -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#04020a"
            android:padding="8dp">

            <TextView
                android:id="@+id/arena_console_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sandbox console initialized. Output logs will appear here."
                android:textColor="@color/text_muted"
                android:fontFamily="monospace"
                android:textSize="11sp" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>
