<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Leaderboard"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Real-time updates of other coders globally. Powered by mock events."
        android:textColor="@color/text_muted"
        android:textSize="12sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="16dp" />

    <!-- Live Event Ticker -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#15FF007F"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/neon_magenta"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="LIVE"
            android:textColor="@color/white"
            android:textSize="9sp"
            android:textStyle="bold" />

        <View
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/lb_ticker_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="User PyGod solved Algorithm Quest (Medium) in Python: +300 XP"
            android:textColor="@color/text_muted"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Tabs selector -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/lb_tabs_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/bg_surface"
            android:orientation="horizontal"
            android:padding="4dp">
            <!-- Dynamically populated in Kotlin -->
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Rankings Scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/card_bg">

        <LinearLayout
            android:id="@+id/lb_ranks_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp" />
    </ScrollView>
</LinearLayout>
